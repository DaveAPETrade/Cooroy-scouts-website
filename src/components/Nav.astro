---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/sections', label: 'Sections' },
  { href: '/about', label: 'About' },
  { href: '/events', label: 'Events' },
  { href: '/gallery', label: 'Gallery' },
];
---

<header class="bg-scout-maroon text-white sticky top-0 z-50 shadow-md">
  <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">

    <!-- Official Scouts QLD white logo -->
    <a href="/" aria-label="Cooroy Scouts — Home">
      <img src="/logos/scouts-qld-white.png" alt="Scouts Queensland" class="h-16 md:h-20 w-auto" />
    </a>

    <!-- Desktop nav links (md and above) -->
    <ul class="hidden md:flex items-center gap-6 font-semibold text-sm">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="hover:text-scout-gold transition-colors">
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/join"
          class="bg-scout-gold text-scout-navy font-bold px-5 py-2 rounded-full hover:bg-scout-gold-dark transition-colors"
        >
          Join Us
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger button -->
    <button
      id="menu-toggle"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden p-2 rounded focus:outline-none focus:ring-2 focus:ring-scout-gold"
    >
      <span class="block w-6 h-0.5 bg-white mb-1.5"></span>
      <span class="block w-6 h-0.5 bg-white mb-1.5"></span>
      <span class="block w-6 h-0.5 bg-white"></span>
    </button>
  </nav>

  <!-- Mobile dropdown menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-scout-maroon-dark px-4 pb-4 border-t border-white/10"
  >
    <ul class="flex flex-col gap-1 pt-2 font-semibold text-sm">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="block py-2.5 px-2 rounded hover:text-scout-gold hover:bg-white/5 transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="mt-2">
        <a
          href="/join"
          class="block bg-scout-gold text-scout-navy font-bold px-4 py-3 rounded-full text-center hover:bg-scout-gold-dark transition-colors"
        >
          Join Us
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isExpanded));
    menu?.classList.toggle('hidden');
  });

  // Close menu when a nav link is clicked (UX improvement)
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
