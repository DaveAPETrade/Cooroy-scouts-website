---
const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/sections', label: 'Sections' },
  { href: '/about', label: 'About' },
  { href: '/events', label: 'Events' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/join', label: 'Join Us' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-scout-navy text-white">

  <!-- Main footer grid -->
  <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-3 gap-10">

    <!-- Column 1: Group identity -->
    <div>
      <h2 class="font-display font-black text-xl mb-2">Cooroy Scout Group</h2>
      <p class="text-white/80 text-sm leading-relaxed mb-4">
        Adventure starts here. Helping young people aged 5–18 in Cooroy and the Noosa hinterland develop skills, friendships, and a love of the outdoors.
      </p>
      <address class="not-italic text-sm text-white/70">
        <!-- Placeholder address — update with real meeting location -->
        Cooroy, Queensland, Australia
      </address>
    </div>

    <!-- Column 2: Quick links -->
    <div>
      <h3 class="font-display font-bold text-base mb-4 uppercase tracking-wider text-scout-gold">Quick Links</h3>
      <ul class="flex flex-col gap-2 text-sm">
        {quickLinks.map(link => (
          <li>
            <a href={link.href} class="text-white/80 hover:text-scout-gold transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 3: Connect / external links -->
    <div>
      <h3 class="font-display font-bold text-base mb-4 uppercase tracking-wider text-scout-gold">Connect</h3>
      <ul class="flex flex-col gap-3 text-sm">
        <li>
          <a
            href="mailto:info@coorooyscouts.example"
            class="text-white/80 hover:text-scout-gold transition-colors flex items-center gap-2"
          >
            <!-- Email icon (inline SVG) -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Email Us
          </a>
        </li>
        <li>
          <a
            href="https://scoutsqld.com.au"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/80 hover:text-scout-gold transition-colors flex items-center gap-2"
          >
            <!-- External link icon -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Scouts Queensland
          </a>
        </li>
        <li>
          <a
            href="https://scoutsqld.com.au/join/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/80 hover:text-scout-gold transition-colors flex items-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
            </svg>
            Register via Scouts QLD
          </a>
        </li>
        <li>
          <a
            href="https://www.facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/80 hover:text-scout-gold transition-colors flex items-center gap-2"
          >
            <!-- Facebook icon -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Facebook
          </a>
        </li>
      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/15">
    <div class="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-white/60">
      <span>&copy; {currentYear} Cooroy Scout Group</span>
      <span>Part of <a href="https://scoutsqld.com.au" target="_blank" rel="noopener noreferrer" class="hover:text-scout-gold transition-colors">Scouts Queensland</a></span>
    </div>
  </div>

</footer>
