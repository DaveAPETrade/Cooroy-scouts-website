---
import BaseLayout from '../layouts/BaseLayout.astro';

const termProgram = [
  {
    term: 'Term 1, 2026',
    dates: '27 January - 27 March 2026',
    entries: [
      { date: 'Week 1', activity: 'Welcome back and term planning', sections: 'All sections' },
      { date: 'Week 3', activity: 'Bushcraft skills — fire safety and shelter building', sections: 'Cubs, Scouts' },
      { date: 'Week 5', activity: 'Community service day — Cooroy town clean-up', sections: 'All sections' },
      { date: 'Week 7', activity: 'Night navigation challenge', sections: 'Scouts, Venturers' },
      { date: 'Week 9', activity: 'Family camp weekend at Cooroora', sections: 'All sections' },
    ],
  },
];
---

<BaseLayout
  title="Events & Term Program"
  description="See what's happening at Cooroy Scout Group — term programs, upcoming events, and activities across all sections."
>

  <!-- Hero -->
  <section class="bg-scout-maroon text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display font-black text-4xl md:text-5xl lg:text-6xl mb-6 leading-tight">
        Events &amp; Term Program
      </h1>
      <p class="text-lg md:text-xl text-white/85 max-w-2xl mx-auto leading-relaxed">
        A snapshot of what our sections are getting up to each term.
      </p>
    </div>
  </section>

  <!-- Term Program -->
  <section class="bg-white py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="font-display font-black text-3xl md:text-4xl text-scout-navy mb-4">Term Program</h2>
      <p class="text-gray-600 mb-10 max-w-2xl leading-relaxed">
        Our term program is planned by section leaders and reviewed each term. Dates and activities are subject to change — check with your section leader for the latest details.
      </p>

      {termProgram.map((term) => (
        <div class="mb-12">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4 gap-1">
            <h3 class="font-display font-black text-2xl text-scout-navy">{term.term}</h3>
            <span class="text-sm text-gray-500 font-semibold">{term.dates}</span>
          </div>

          <!-- Desktop: table view -->
          <div class="hidden md:block overflow-hidden rounded-xl border border-gray-200">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="bg-scout-maroon text-white">
                  <th class="px-5 py-3 text-left font-display font-bold w-24">Date</th>
                  <th class="px-5 py-3 text-left font-display font-bold">Activity</th>
                  <th class="px-5 py-3 text-left font-display font-bold w-44">Sections</th>
                </tr>
              </thead>
              <tbody>
                {term.entries.map((entry, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                    <td class="px-5 py-4 text-gray-500 font-semibold whitespace-nowrap">{entry.date}</td>
                    <td class="px-5 py-4 text-gray-800 leading-snug">{entry.activity}</td>
                    <td class="px-5 py-4 text-gray-600">{entry.sections}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <!-- Mobile: card list -->
          <div class="md:hidden space-y-3">
            {term.entries.map((entry) => (
              <div class="rounded-xl border border-gray-200 p-4 bg-white">
                <div class="flex items-start justify-between gap-3 mb-1">
                  <span class="text-xs font-bold text-scout-maroon uppercase tracking-wide">{entry.date}</span>
                  <span class="text-xs text-gray-500 font-semibold shrink-0">{entry.sections}</span>
                </div>
                <p class="text-sm text-gray-800 leading-snug">{entry.activity}</p>
              </div>
            ))}
          </div>
        </div>
      ))}

      <!-- Mailing list callout -->
      <div class="bg-scout-gold/10 border-l-4 border-scout-gold p-5 rounded-r-xl mt-4">
        <p class="text-gray-700 text-sm leading-relaxed">
          <strong class="text-scout-navy">Want to know about specific upcoming events?</strong>
          {' '}Get in touch and we'll add you to our mailing list.{' '}
          <a href="/join" class="text-scout-maroon font-semibold hover:text-scout-maroon-dark transition-colors">
            Contact us &rarr;
          </a>
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gray-50 py-12">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-display font-black text-2xl md:text-3xl text-scout-navy mb-3">
        Questions about our program?
      </h2>
      <p class="text-gray-600 mb-6">
        Reach out and a leader will get back to you with the details.
      </p>
      <a
        href="/join"
        class="bg-scout-maroon text-white font-display font-bold text-base px-8 py-4 rounded-full hover:bg-scout-maroon-dark transition-colors inline-block"
      >
        Get in Touch
      </a>
    </div>
  </section>

</BaseLayout>
