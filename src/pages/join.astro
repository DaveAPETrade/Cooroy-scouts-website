---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  { name: 'Joeys', ages: '5–7 years', color: 'bg-section-joeys', textColor: 'text-white' },
  { name: 'Cubs', ages: '8–10 years', color: 'bg-section-cubs', textColor: 'text-amber-900' },
  { name: 'Scouts', ages: '11–14 years', color: 'bg-section-scouts', textColor: 'text-white' },
  { name: 'Venturers', ages: '15–17 years', color: 'bg-section-venturers', textColor: 'text-white' },
];
---

<BaseLayout
  title="Join Us"
  description="Get in touch with Cooroy Scout Group and we'll help your young person find the right section to join."
>

  <!-- Hero -->
  <section class="bg-scout-maroon text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-display font-black text-4xl md:text-5xl lg:text-6xl mb-6 leading-tight">
        Join Cooroy Scouts
      </h1>
      <p class="text-lg md:text-xl text-white/85 max-w-2xl mx-auto leading-relaxed">
        Get in touch and we'll help your young person find the right section.
      </p>
    </div>
  </section>

  <!-- Two-column layout: form + info -->
  <section class="bg-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

        <!-- Left: Contact form -->
        <div>
          <h2 class="font-display font-black text-2xl md:text-3xl text-scout-navy mb-6">
            Send Us an Inquiry
          </h2>

          <!-- Result message (shown after submission) -->
          <div id="result" class="hidden mb-4 p-4 rounded-lg text-sm font-semibold"></div>

          <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" novalidate>
            <!-- Web3Forms hidden fields -->
            <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
            <input type="hidden" name="subject" value="New Scouts Inquiry from Cooroy Scouts Website" />
            <input type="hidden" name="from_name" value="Cooroy Scouts Website" />

            <!-- Honeypot anti-spam -->
            <input type="checkbox" name="botcheck" class="hidden" style="display: none" />

            <div class="space-y-5">
              <!-- Your Name -->
              <div>
                <label for="name" class="block font-semibold text-sm text-gray-700 mb-1">
                  Your Name <span class="text-scout-maroon">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Jane Smith"
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-scout-maroon transition-shadow"
                />
              </div>

              <!-- Email Address -->
              <div>
                <label for="email" class="block font-semibold text-sm text-gray-700 mb-1">
                  Email Address <span class="text-scout-maroon">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  placeholder="jane@example.com"
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-scout-maroon transition-shadow"
                />
              </div>

              <!-- Child's Age -->
              <div>
                <label for="child_age" class="block font-semibold text-sm text-gray-700 mb-1">
                  Child's Age <span class="text-scout-maroon">*</span>
                </label>
                <input
                  type="number"
                  id="child_age"
                  name="child_age"
                  min="4"
                  max="25"
                  required
                  placeholder="e.g. 9"
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-scout-maroon transition-shadow"
                />
                <p class="text-xs text-gray-500 mt-1">We'll suggest the right section based on your child's age.</p>
              </div>

              <!-- Message (optional) -->
              <div>
                <label for="message" class="block font-semibold text-sm text-gray-700 mb-1">
                  Message <span class="text-gray-400 font-normal">(optional)</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  placeholder="Any questions or things we should know?"
                  class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-scout-maroon transition-shadow resize-none"
                ></textarea>
              </div>

              <!-- hCaptcha widget (rendered by Web3Forms client script) -->
              <div class="h-captcha" data-captcha="true"></div>

              <!-- Submit button -->
              <button
                type="submit"
                id="submit-btn"
                class="bg-scout-gold text-scout-navy font-display font-bold px-8 py-4 rounded-full hover:bg-scout-gold-dark transition-colors w-full text-base"
              >
                Send Inquiry
              </button>
            </div>
          </form>
        </div>

        <!-- Right: Section info -->
        <div>
          <h2 class="font-display font-black text-2xl md:text-3xl text-scout-navy mb-6">
            Which Section is Right?
          </h2>

          <div class="space-y-3 mb-8">
            {sections.map((s) => (
              <div class="rounded-xl overflow-hidden border border-gray-100 flex items-center">
                <div class={`${s.color} ${s.textColor} px-5 py-4 w-32 shrink-0`}>
                  <p class="font-display font-black text-base">{s.name}</p>
                  <p class="text-xs font-semibold opacity-80">{s.ages}</p>
                </div>
                <div class="px-5 py-4">
                  <a
                    href={`/sections/${s.name.toLowerCase()}`}
                    class="text-sm text-scout-maroon font-semibold hover:text-scout-maroon-dark transition-colors"
                  >
                    Learn about {s.name} &rarr;
                  </a>
                </div>
              </div>
            ))}
          </div>

          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <h3 class="font-display font-bold text-lg text-scout-navy mb-2">Not sure which section?</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              That's completely fine — just tell us your child's age and we'll point you to the right section leader. We're happy to answer any questions before you commit to anything.
            </p>
          </div>

          <div class="mt-6 bg-scout-maroon/5 border border-scout-maroon/20 rounded-2xl p-6">
            <h3 class="font-display font-bold text-lg text-scout-navy mb-2">What happens next?</h3>
            <ol class="text-sm text-gray-700 space-y-2 leading-relaxed list-none">
              <li class="flex gap-3">
                <span class="font-bold text-scout-maroon shrink-0">1.</span>
                <span>We'll reply to your email within a few days.</span>
              </li>
              <li class="flex gap-3">
                <span class="font-bold text-scout-maroon shrink-0">2.</span>
                <span>We'll invite your young person to come along to a session — no commitment required.</span>
              </li>
              <li class="flex gap-3">
                <span class="font-bold text-scout-maroon shrink-0">3.</span>
                <span>If it's a good fit, we'll walk you through the Scouts Queensland registration process.</span>
              </li>
            </ol>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<!-- Web3Forms client script — handles hCaptcha widget rendering -->
<script src="https://web3forms.com/client/script.js" async defer></script>

<!-- Form submission handler -->
<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const result = document.getElementById('result') as HTMLDivElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    result.className = 'mb-4 p-4 rounded-lg text-sm font-semibold';
    result.textContent = 'Please wait...';
    result.classList.remove('hidden');

    const formData = new FormData(form);
    const object = Object.fromEntries(formData.entries());
    const json = JSON.stringify(object);

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: json,
      });
      const data = await response.json();

      if (data.success) {
        result.classList.add('bg-green-100', 'text-green-800');
        result.textContent = "Thank you! We'll be in touch soon.";
        form.reset();
      } else {
        result.classList.add('bg-red-100', 'text-red-800');
        result.textContent = data.message ?? 'Something went wrong. Please try again.';
      }
    } catch {
      result.classList.add('bg-red-100', 'text-red-800');
      result.textContent = 'Network error. Please try again.';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Inquiry';
      setTimeout(() => result.classList.add('hidden'), 6000);
    }
  });
</script>
